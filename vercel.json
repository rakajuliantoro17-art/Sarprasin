{
  "rewrites": [
    { "source": "/", "destination": "/user/index.html" },

    { "source": "/user", "destination": "/user/index.html" },
    { "source": "/user/(.*)", "destination": "/user/$1" },

    { "source": "/executive", "destination": "/executive/index.html" },
    { "source": "/executive/(.*)", "destination": "/executive/$1" },

    { "source": "/public", "destination": "/public/index.html" },
    { "source": "/public/(.*)", "destination": "/public/$1" }
  ]
}
