```json
{
  "routes": [
    { "src": "^/$", "dest": "/user/index.html" },

    { "src": "^/user$", "dest": "/user/index.html" },
    { "src": "^/user/(.*)", "dest": "/user/$1" },

    { "src": "^/executive$", "dest": "/executive/index.html" },
    { "src": "^/executive/(.*)", "dest": "/executive/$1" },

    { "src": "^/public$", "dest": "/public/index.html" },
    { "src": "^/public/(.*)", "dest": "/public/$1" }
  ]
}
```


